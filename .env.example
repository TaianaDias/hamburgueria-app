PORT=3000
DEFAULT_EMPRESA_ID=default
DEFAULT_LOJA_ID=matriz

# Cloud Run recomendado:
# publique com uma service account do Google e nao preencha nenhuma variavel FIREBASE_.

# Fora do Cloud Run, use uma das opcoes abaixo para o Firebase Admin.
# No Render, a opcao mais simples e FIREBASE_SERVICE_ACCOUNT_JSON.

# Opcao 1: cole o JSON completo da service account em uma unica linha.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"seu-projeto","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@seu-projeto.iam.gserviceaccount.com"}

# Opcao 2: use variaveis separadas.
# FIREBASE_PROJECT_ID=seu-projeto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Opcao 3: aponte para um arquivo JSON local ou secret file.
# FIREBASE_SERVICE_ACCOUNT_FILE=server/serviceAccountKey.json

# Consulta principal de codigo de barras via Cosmos.
# Crie sua conta no Cosmos/Bluesoft e pegue o token no painel da API.
# COSMOS_API_TOKEN=seu-token
# COSMOS_USER_AGENT=SuaEmpresa/1.0 (contato@empresa.com)

# Estrutura preparada para integracoes futuras de WhatsApp.
# Deixe vazio se quiser usar apenas log/painel interno por enquanto.
# WHATSAPP_PROVIDER=meta
# WHATSAPP_WEBHOOK_TOKEN=token-interno-para-validar-webhook
# WHATSAPP_ADMIN_PHONE=5511999999999
# WHATSAPP_STORE_PHONE=5511888888888
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# ZAPI_INSTANCE_ID=
# ZAPI_INSTANCE_TOKEN=
# ZAPI_CLIENT_TOKEN=
# EVOLUTION_API_URL=
# EVOLUTION_API_TOKEN=
# EVOLUTION_INSTANCE_NAME=

# Evolution API v2 - integração oficial do WhatsApp interno.
# Use no backend/Render. Nunca exponha a chave no front-end.
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=colocar_chave_aqui
EVOLUTION_INSTANCE=cariocas-estoque
EVOLUTION_INSTANCE_TOKEN=token_da_instancia_se_existir
ADMIN_WHATSAPP=5521999999999
# Separe por vírgula se quiser liberar outros números sem cadastrar usuário.
# WHATSAPP_ALLOWED_PHONES=5521988888888,5521977777777
# EVOLUTION_WEBHOOK_TOKEN=token-interno
# AUTHENTICATION_API_KEY=mesma_chave_global_do_docker_compose

# ULTRAMSG_INSTANCE_ID=
# ULTRAMSG_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_TOKEN=

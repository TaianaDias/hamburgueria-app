{
  "name": "hamburgueria-app",
  "version": "1.0.0",
  "description": "Painel operacional para hamburgueria com Firebase",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "start:whatsapp-local": "powershell -ExecutionPolicy Bypass -File scripts/start-whatsapp-local.ps1",
    "whatsapp:health": "node scripts/whatsapp-health.mjs",
    "build:css": "node scripts/build-css.mjs",
    "watch:css": "node scripts/build-css.mjs --watch",
    "check:html": "node scripts/check-html-modules.mjs",
    "check:smoke": "node scripts/smoke-test.mjs",
    "check:phase3": "node scripts/phase3-visual-check.mjs",
    "check:phase4": "node scripts/phase4-authenticated-audit.mjs",
    "check:phase5": "node scripts/phase5-operational-validation.mjs",
    "diag:fornecedores-phase5": "node scripts/phase5-fornecedores-diagnostic.mjs",
    "audit:firestore-user": "node scripts/phase4-firestore-usuario.mjs",
    "ci": "npm run build:css && npm run check:html && npm run check:smoke",
    "mobile:copy": "npx cap copy",
    "mobile:sync": "npx cap sync",
    "mobile:doctor": "npx cap doctor",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "playwright": "^1.52.0"
  }
}
